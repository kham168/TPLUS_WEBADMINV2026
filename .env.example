# Copy this file to `.env` and fill in the values before running `npm run build`.
# `.env` itself is git-ignored, so it must be created on each machine/server.

VUE_APP_I18N_LOCALE=la
VUE_APP_I18N_FALLBACK_LOCALE=en
VUE_APP_I18N_SUPPORTED_LOCALE=la,en

# Base URL used by src/plugins/Axios.js ($axios / $http)
VUE_APP_BASE_API_URL=https://api.tplus.la/web-api/api/v1/

# Base URL used by login (src/store/User.js) AND the resource providers
# (src/resources/http_request.js). Must be set or logins and data calls hit
# the wrong host. Keep it the same as VUE_APP_BASE_API_URL.
VUE_APP_BASE_API_URL_TEST=https://api.tplus.la/web-api/api/v1/
